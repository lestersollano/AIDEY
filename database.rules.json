{
  "rules": {
    "documentUploads": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "$documentId": {
          "$imageId": {
            ".validate": "newData.hasChildren(['remoteUrl', 'storagePath', 'updatedAt'])",

            "remoteUrl": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().beginsWith('https://')"
            },

            "storagePath": {
              ".validate": "newData.isString() && newData.val().beginsWith('documents/' + $uid + '/' + $documentId + '/' + $imageId)"
            },

            "updatedAt": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },

            "$other": {
              ".validate": false
            }
          }
        }
      }
    },

    "chatSessions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "$sessionId": {
          ".validate": "newData.hasChildren(['title', 'updatedAt'])",

          "title": {
            ".validate": "newData.isString()"
          },

          "documentId": {
            ".validate": "newData.isString() || newData.val() == null"
          },

          "documentLabel": {
            ".validate": "newData.isString() || newData.val() == null"
          },

          "messages": {
            "$index": {
              ".validate": "newData.hasChildren(['id', 'role', 'text'])",

              "id": {
                ".validate": "newData.isString() && newData.val().length > 0"
              },

              "role": {
                ".validate": "newData.val() === 'user' || newData.val() === 'assistant'"
              },

              "text": {
                ".validate": "newData.isString()"
              },

              "model": {
                ".validate": "newData.isString() || newData.val() == null"
              },

              "isArrivalCheck": {
                ".validate": "newData.isBoolean() || newData.val() == null"
              }
            }
          },

          "checklist": {
            "$index": {
              ".validate": "newData.hasChildren(['id', 'label', 'done'])",

              "id": {
                ".validate": "newData.isString() && newData.val().length > 0"
              },

              "label": {
                ".validate": "newData.isString() && newData.val().length > 0"
              },

              "done": {
                ".validate": "newData.isBoolean()"
              },

              "$other": {
                ".validate": false
              }
            }
          },

          "archived": {
            ".validate": "newData.isBoolean()"
          },

          "createdAt": {
            ".validate": "newData.isNumber()"
          },

          "updatedAt": {
            ".validate": "newData.isNumber() && newData.val() <= now"
          }
        }
      }
    },

    "documentGuideProgress": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "$documentId": {
          ".validate": "newData.hasChildren(['updatedAt'])",

          "checkedRequirements": {
            "$index": {
              ".validate": "newData.isNumber()"
            }
          },

          "checkedSteps": {
            "$index": {
              ".validate": "newData.isNumber()"
            }
          },

          "completedSections": {
            "$index": {
              ".validate": "newData.val() === 'requirements' || newData.val() === 'steps' || newData.val() === 'upload'"
            }
          },

          "updatedAt": {
            ".validate": "newData.isNumber() && newData.val() <= now"
          },

          "$other": {
            ".validate": false
          }
        }
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
