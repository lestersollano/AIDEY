{
  "expo": {
    "name": "aidey",
    "slug": "aidey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO.png",
    "scheme": "aidey",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/LOGO.png",
      "bundleIdentifier": "com.glak.aidey"
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#ffffff",
      "translucent": false
    },
    "android": {
      "package": "com.glak.aidey",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#208AEF",
        "foregroundImage": "./assets/LOGO.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/LOGO.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/LOGO.png",
            "imageWidth": 200
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ab3e097-ea29-4ba6-8097-4e447fbb7fe1"
      }
    },
    "owner": "lesterr"
  }
}
